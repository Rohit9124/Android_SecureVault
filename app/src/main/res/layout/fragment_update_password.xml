<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".view.activities.MainViewActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_col_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.07" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_col_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.11" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_col_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.89" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_col_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.93" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_split_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.48" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_split_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.52" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.02" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.09" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.18" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.31" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.44" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_6_5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.57" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_buttons_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_row_buttons_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.95" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jetbrainsmonoextrabold"
        android:text="@string/update_update"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toTopOf="@+id/guideline_header" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_back"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toTopOf="@+id/guideline_row_1" />


    <ImageView
        android:id="@+id/background_inputbox_1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/background_inputbox"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_3"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_4"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toTopOf="@+id/guideline_row_2" />

    <EditText
        android:id="@+id/name_input2"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="@color/background_secondary"
        android:ems="10"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:gravity="center_vertical"
        android:hint="@string/update_name"
        android:inputType="text"
        android:paddingHorizontal="4dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_1"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_3"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_2"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_1" />


    <ImageView
        android:id="@+id/background_inputbox_2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/background_inputbox"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_4"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_4"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toBottomOf="@+id/background_inputbox_1" />

    <EditText
        android:id="@+id/email_input2"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="@color/background_secondary"
        android:ems="10"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:gravity="center_vertical"
        android:hint="@string/update_email"
        android:inputType="text"
        android:paddingHorizontal="4dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_2"
        app:layout_constraintEnd_toStartOf="@+id/copy_button_email"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_2"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_2"
        tools:ignore="TextFields" />

    <ImageButton
        android:id="@+id/copy_button_email"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_copy"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_2"
        app:layout_constraintEnd_toEndOf="@+id/background_inputbox_2"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_2" />


    <ImageView
        android:id="@+id/background_inputbox_website"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/background_inputbox"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_6_5"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_4"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toBottomOf="@+id/background_inputbox_2" />

    <EditText
        android:id="@+id/website_input2"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="@color/background_secondary"
        android:ems="10"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:gravity="center_vertical"
        android:hint="Website URL (optional)"
        android:inputType="textUri"
        android:paddingHorizontal="4dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_website"
        app:layout_constraintEnd_toStartOf="@+id/copy_button_website"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_2"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_website"
        tools:ignore="TextFields" />

    <ImageButton
        android:id="@+id/copy_button_website"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_copy"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_website"
        app:layout_constraintEnd_toEndOf="@+id/background_inputbox_website"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_website" />


    <ImageView
        android:id="@+id/background_inputbox_3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/background_inputbox"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_7"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_4"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toBottomOf="@+id/background_inputbox_website" />

    <EditText
        android:id="@+id/password_input2"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="@color/background_secondary"
        android:ems="10"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:gravity="center_vertical"
        android:hint="@string/update_password"
        android:inputType="textPassword"
        android:paddingHorizontal="4dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_3"
        app:layout_constraintEnd_toStartOf="@+id/password_visibility_button"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_2"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_3"
        tools:ignore="TextFields" />

    <ImageButton
        android:id="@+id/copy_button_password"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_copy"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_3"
        app:layout_constraintEnd_toEndOf="@+id/background_inputbox_3"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_3" />

    <ImageButton
        android:id="@+id/password_visibility_button"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/icon_visibility_on"
        app:layout_constraintBottom_toBottomOf="@+id/background_inputbox_3"
        app:layout_constraintEnd_toStartOf="@+id/copy_button_password"
        app:layout_constraintTop_toTopOf="@+id/background_inputbox_3" />


    <ImageButton
        android:id="@+id/update_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn2"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_buttons_bottom"
        app:layout_constraintEnd_toStartOf="@+id/guideline_split_left"
        app:layout_constraintStart_toStartOf="@+id/guideline_col_1"
        app:layout_constraintTop_toTopOf="@+id/guideline_row_buttons_top" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:text="@string/update_btn_update"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/update_button"
        app:layout_constraintEnd_toEndOf="@+id/update_button"
        app:layout_constraintStart_toStartOf="@+id/update_button"
        app:layout_constraintTop_toTopOf="@+id/update_button" />

    <ImageButton
        android:id="@+id/delete_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="1dp"
        android:scaleType="fitCenter"
        android:src="@drawable/btn"
        app:layout_constraintBottom_toTopOf="@+id/guideline_row_buttons_bottom"
        app:layout_constraintEnd_toStartOf="@+id/guideline_col_4"
        app:layout_constraintStart_toStartOf="@+id/guideline_split_right"
        app:layout_constraintTop_toTopOf="@+id/guideline_row_buttons_top" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jetbrainsmonoregular"
        android:text="@string/update_btn_delete"
        android:textColor="@color/background_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/delete_button"
        app:layout_constraintEnd_toEndOf="@+id/delete_button"
        app:layout_constraintStart_toStartOf="@+id/delete_button"
        app:layout_constraintTop_toTopOf="@+id/delete_button" />

</androidx.constraintlayout.widget.ConstraintLayout>